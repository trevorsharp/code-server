{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "enabled_providers": [
    "openai",
    "github-copilot"
  ],
  "formatter": {
    "csharpier": {
      "command": [
        "csharpier",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".cs",
        ".csproj",
        ".slnx"
      ]
    }
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "cors": [
      "http://localhost:4096",
      "https://work.trs.dev"
    ]
  },
  "permission": {
    "*": "allow"
  },
  "mcp": {
    "Jira": {
      "type": "remote",
      "url": "https://jira-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "Google Drive": {
      "type": "remote",
      "url": "https://gdrive-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "Slack": {
      "type": "remote",
      "url": "https://slack-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "Snowflake": {
      "type": "remote",
      "url": "https://snowflake-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "Splunk": {
      "type": "remote",
      "url": "https://splunk-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "Fastlane": {
      "type": "remote",
      "url": "https://fastlane-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "Carvana Publish": {
      "type": "remote",
      "url": "https://publish-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "Datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp",
      "enabled": false
    },
    "Chrome DevTools": {
      "type": "local",
      "command": [
        "bun",
        "/home/sharp/.config/opencode/mcp/chrome-devtools-host.ts"
      ],
      "env": {
        "CDP_HOST": "host.docker.internal",
        "CDP_PORT": "9222",
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1"
      },
      "enabled": false
    }
  }
}