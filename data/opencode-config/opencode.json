{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "enabled_providers": [
    "google-vertex-anthropic",
    "openai"
  ],
  "provider": {
    "google-vertex-anthropic": {
      "options": {
        "project": "crv-engineering-ai-prd-8058",
        "location": "global"
      }
    }
  },
  "model": "openai/gpt-5.5",
  "formatter": {
    "csharpier": {
      "command": [
        "csharpier",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".cs",
        ".csproj"
      ]
    }
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "cors": [
      "http://localhost:4096",
      "https://work.trs.dev"
    ]
  },
  "permission": {
    "*": "allow"
  },
  "mcp": {
    "jira": {
      "type": "remote",
      "url": "https://jira-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "google-drive": {
      "type": "remote",
      "url": "https://gdrive-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "slack": {
      "type": "remote",
      "url": "https://slack-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "snowflake": {
      "type": "remote",
      "url": "https://snowflake-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "splunk": {
      "type": "remote",
      "url": "https://splunk-mcp.cvnacorp.com/mcp",
      "enabled": false
    },
    "fastlane": {
      "type": "remote",
      "url": "https://fastlane-mcp.cvnacorp.com/mcp",
      "enabled": false
    }
  }
}