{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "enabled_providers": [
    "openai"
  ],
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "cors": [
      "http://localhost:4096",
      "https://ai.trs.dev"
    ]
  },
  "permission": {
    "*": "allow"
  },
  "tools": {
    "task": false
  },
  "mcp": {
    "Chrome DevTools": {
      "type": "local",
      "command": [
        "bun",
        "/home/sharp/.config/opencode/mcp/chrome-devtools.ts"
      ],
      "env": {
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1"
      },
      "enabled": false
    }
  }
}
